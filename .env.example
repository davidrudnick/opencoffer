# Postgres
# Docker Compose uses postgres://opencoffer:opencoffer@postgres:5432/opencoffer.
# For local non-Docker development use postgres://opencoffer:opencoffer@localhost:5432/opencoffer.
DATABASE_URL=postgres://opencoffer:opencoffer@postgres:5432/opencoffer

# Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000

# 32-byte base64 master key for SimpleFIN access URLs + user LLM API keys
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-me

# Public-facing URL used in MCP setup snippets.
APP_URL=http://localhost:3000

# Worker sync cadence. Defaults to every 30 minutes when unset.
# Cron syntax: minute hour day-of-month month day-of-week
OPENCOFFER_SYNC_CRON=*/30 * * * *

# Optional: pre-seeded Ollama base URL inside the compose network
OLLAMA_BASE_URL=http://ollama:11434/v1
